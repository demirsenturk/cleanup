# Azure Subscription Cleanup - .gitignore

# Azure CLI
.azure/

# Bash script temporary files
*.swp
*.swo
*~
.*.sw?

# Log files
*.log
logs/
*.txt

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and Editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.vim/

# Backup files
*.bak
*.backup
*.old
*.orig

# Test and temporary files
temp/
tmp/
test-output/
.scratch/

# Environment variables
.env
.env.local
*.env

# Azure specific
*.publishsettings
*.azurePubxml

# Script output
output/
reports/
